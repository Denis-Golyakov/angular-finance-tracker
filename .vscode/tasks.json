    // ─── Generate ──────────────────────────────────────────────────
    {
      "label": "generate: component",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "exec",
        "ng",
        "generate",
        "component",
        "${input:componentPath}"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "angular",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "generate: service",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "exec",
