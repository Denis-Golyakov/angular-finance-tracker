{
  "version": "2.0.0",
  "tasks": [
    // ─── Dev Server ────────────────────────────────────────────────
    {
      "label": "serve",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "exec",
        "ng",
        "serve",
        "--open"
      ],
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "group": "angular"
      },
      "problemMatcher": {
        "owner": "angular",
        "pattern": {
          "regexp": "^ERROR in (.*):(\\d+):(\\d+)$",
          "file": 1,
          "line": 2,
          "column": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building\\.\\.\\.",
          "endsPattern": "compiled successfully"
        }
      }
    },
    // ─── Build ─────────────────────────────────────────────────────
    {
      "label": "build",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "exec",
        "ng",
        "build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "angular"
      },
      "problemMatcher": [
        "$tsc"
      ]
    },
