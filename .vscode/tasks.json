    {
      "label": "update: check",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "exec",
        "ng",
        "update"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "angular"
      },
      "problemMatcher": []
    }
  ],
  // ─── Inputs ──────────────────────────────────────────────────────
  "inputs": [
    {
      "id": "componentPath",
      "type": "promptString",
      "description": "Component path (e.g. components/spending-chart or pages/dashboard)"
    },
    {
      "id": "servicePath",
      "type": "promptString",
      "description": "Service path (e.g. services/storage)"
    },
    {
      "id": "pipePath",
      "type": "promptString",
      "description": "Pipe path (e.g. pipes/currency-format)"
    },
    {
      "id": "guardPath",
      "type": "promptString",
      "description": "Guard path (e.g. guards/auth)"
    }
  ]
