    {
      "label": "test",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "exec",
        "ng",
        "test"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "angular"
      },
      "problemMatcher": []
    },
    {
      "label": "test:ci",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "exec",
        "ng",
        "test",
        "--watch=false",
        "--browsers=ChromeHeadless"
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "angular"
      },
      "problemMatcher": []
    },
